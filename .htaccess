RewriteEngine On
RewriteCond %{HTTP_HOST} ^suretekinfosoft\.com$ [NC]
RewriteRule ^(.*)$ https://www.suretekinfosoft.com/$1 [L,R=301]

#RewriteCond %{HTTP_HOST} !^www\.suretekinfosoft\.com [NC]

#RewriteRule ^(.*)$ https://www.suretekinfosoft.com/$1 [L,R=301]

# 🔹 Skip redirect if the request is already for the "portfolio" subdomain
RewriteCond %{HTTP_HOST} ^portfolio\.suretekinfosoft\.com$ [NC]
RewriteRule ^ - [L]

# 🔹 Redirect all other non-www requests to www
RewriteCond %{HTTP_HOST} !^www\.suretekinfosoft\.com$ [NC]
RewriteCond %{HTTP_HOST} ^suretekinfosoft\.com$ [NC]
RewriteRule ^(.*)$ https://www.suretekinfosoft.com/$1 [L,R=301]



# Ensure mod_rewrite is enabled

RewriteEngine On



